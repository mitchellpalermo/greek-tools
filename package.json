{
  "name": "greek-tools",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/build-morphgnt.mjs && node scripts/build-vocabulary.mjs && astro build",
    "build:data": "node scripts/build-morphgnt.mjs && node scripts/build-vocabulary.mjs",
    "build:data:force": "node scripts/build-morphgnt.mjs --force && node scripts/build-vocabulary.mjs --force",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.17.1",
    "posthog-js": "^1.240.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.68.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": ["biome check --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "simple-git-hooks",
      "workerd"
    ]
  }
}
